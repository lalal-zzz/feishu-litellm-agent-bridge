@echo off
:: 设置本窗口的编码为 UTF-8，防止中文乱码
chcp 65001 >nul
title 双启控制台 - 智能助手大后方

echo ===================================================
echo             正在初始化 AI 智能助手大后方...
echo ===================================================



:: 设置 Claude Code 的环境变量，指向我们本地的 LiteLLM 网关
set ANTHROPIC_MODEL=claude-deepseek-v4flash
set ANTHROPIC_BASE_URL=http://127.0.0.1:4000
set ANTHROPIC_AUTH_TOKEN=sk-my-secret-gateway-key
set PYTHONPATH=C:\ai-bridge

:: ----------------------------------------------------
:: 2. 启动窗口一：LiteLLM 统一网关 (端口 4000)
:: ----------------------------------------------------
echo 1. 正在启动 LiteLLM 统一模型网关...
:: 使用 start 弹出新窗口，/k 参数确保窗口报错时不会自动闪退，方便看日志
start "LiteLLM Gateway [Port:4000]" cmd /k "cd /d C:\ai-bridge && litellm --config litellm_config.yaml --port 4000"

:: ----------------------------------------------------
:: 3. 稍微等待 3 秒，确保网关已经成功跑起来，再启动飞书
:: ----------------------------------------------------
timeout /t 3 /nobreak >nul

:: ----------------------------------------------------
:: 4. 启动窗口二：飞书桥接器
:: ----------------------------------------------------
echo 2. 正在启动飞书桥接器...
start "Feishu IM Bridge" cmd /k "lark-channel-bridge run --skip-check-lark-cli"

echo ===================================================
echo                 🎉 所有服务启动完毕！
echo ===================================================
echo  1. 电脑桌面上会多出两个黑窗口，分别是网关和飞书的日志。
echo  2. 您可以通过查看这两个窗口，随时确认飞书传输和 API 调用。
echo  3. 现在可以拿起手机，在飞书里和您的 AI 助手愉快地聊天了。
echo ===================================================
pause